# DB Info
DB_HOST=127.0.0.1
DB_NAME=
DB_USER=
DB_PASSWORD=

# ِEmail Info
MAIL_APP_NAME=
MAIL_GET_EMAIL=
MAIL_SEND_EMAIL=

# APP Config
APP_NAME=WT App
APP_TZ=Asia/Riyadh
APP_DEBUG=false
APP_CACHE=false
APP_SECRET_KEY=change-this-to-a-long-random-string

# WhatsApp Cloud API (plugin: WT\Plugins\Whatsapp) — from Meta / developers.facebook.com
WHATSAPP_API_VERSION=v21.0
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
WHATSAPP_BUSINESS_ID=

# Stripe Payments (plugin: WT\Plugins\Stripe) — from dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=

# ── SMTP (optional). Set SMTP_HOST to send via SMTP instead of PHP mail().
# Recommended for production — mail() often lands in spam or fails silently.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls
SMTP_FROM=
SMTP_FROM_NAME=
