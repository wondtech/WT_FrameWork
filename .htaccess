# ── 1. Security: deny sensitive files ────────────────────────────────────
<Files ".env">
    Require all denied
</Files>

RewriteEngine On

# ── 2. API Authorization ──────────────────────────────────────────────────
RewriteCond %{HTTP:Authorization} .
RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# ── 3. Force HTTPS ────────────────────────────────────────────────────────
RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── 4. Security: deny direct directory/file access ────────────────────────
RewriteRule ^wt/ - [F,L]
RewriteRule ^pub_wt/+$ - [F,L]
RewriteRule ^pub_wt/css/+$ - [F,L]
RewriteRule ^pub_wt/fonts/+$ - [F,L]
RewriteRule ^pub_wt/imgs/+$ - [F,L]
RewriteRule ^pub_wt/js/+$ - [F,L]

# ── 5. Minify pipeline ────────────────────────────────────────────────────
RewriteRule ^pub_wt/js/(.+)\.js$ pub_wt/js/wt_minify_js.php?file=$1.js [L,QSA]
RewriteRule ^pub_wt/css/(.+)\.css$ pub_wt/css/wt_minify_css.php?file=$1.css [L,QSA]

# ── 6. Front controller catch-all ─────────────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [L,QSA]